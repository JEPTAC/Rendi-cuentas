rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return signedIn() ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data : null;
    }

    function isSuperAdmin() {
      return signedIn() && userDoc().activo == true && userDoc().role == 'super_admin';
    }

    function isActiveInternalUser() {
      return signedIn() && userDoc().activo == true;
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /responsables/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /users/{docId} {
      allow read: if isActiveInternalUser();
      allow create, update, delete: if isSuperAdmin();
    }

    match /solicitudes/{docId} {
      allow create: if true;
      allow read, update: if isActiveInternalUser();
      allow delete: if isSuperAdmin();
    }

    match /publicResponses/{docId} {
      allow read: if true;
      allow create: if true;
      allow update: if isActiveInternalUser();
      allow delete: if isSuperAdmin();
    }

    match /auditoria/{docId} {
      allow create: if true;
      allow read: if isActiveInternalUser();
      allow update, delete: if isSuperAdmin();
    }

    match /counters/{docId} {
      allow read, write: if isActiveInternalUser();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
